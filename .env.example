# ============================================
# INFRAESTRUCTURA SGD - Variables de Entorno
# Copia este archivo a .env y rellena con tus valores reales
# ============================================

# --- Dominio ---
DOMAIN=tudominio.com

# --- Paths a los repos (relativos a sgd-infra/) ---
LARAVEL_PATH=../SDG-Back-api
OSAI_PATH=../OSAI
FRONTEND_DIST_PATH=../SGD-Front/dist/spa
OSAI_CREDENTIALS_PATH=../OSAI/credentials

# --- Oracle XE ---
ORACLE_PASSWORD=StrongPassword123!
DB_USERNAME=SGD_MR7
DB_PASSWORD=sgd123

# --- Redis ---
REDIS_PASSWORD=

# --- Laravel APP_KEY ---
# Generar con: php artisan key:generate --show
APP_KEY=base64:coloca_aqui_tu_app_key_generada

# --- Token compartido OSAI <-> Laravel ---
# Debe coincidir con API_KEY_TOKEN de OSAI/.env
# Generar con: openssl rand -hex 32
OSAI_API_TOKEN=coloca_aqui_un_token_secreto_compartido

# --- Reverb (WebSocket) ---
# Generar con: openssl rand -hex 16
REVERB_APP_ID=coloca_aqui_reverb_app_id
REVERB_APP_KEY=coloca_aqui_reverb_app_key
REVERB_APP_SECRET=coloca_aqui_reverb_app_secret

# --- Backblaze B2 (almacenamiento de archivos) ---
B2_KEY_ID=tu_b2_key_id_aqui
B2_APPLICATION_KEY=tu_b2_application_key_aqui
B2_BUCKET=sgd-mr7
B2_ENDPOINT=https://s3.us-east-005.backblazeb2.com
B2_REGION=us-east-005
B2_KEY_NAME=sgd-mr7

# --- Passport ---
PASSPORT_CLIENT_ID=2
PASSPORT_CLIENT_SECRET=coloca_aqui_passport_client_secret

# --- Mail (Mailtrap o SMTP real) ---
MAIL_MAILER=log
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@tudominio.com

# --- IA: Proveedores (OSAI) ---
AI_SELECTOR=DEEPSEEK
AI_SELECTOR_EMERGENCY=GEMINI
AI_SELECTOR_VISION=GEMINI

# --- IA: Modelos ---
MODEL_GEMINI=gemini-2.5-flash
MODEL_DEEPSEEK=deepseek-chat
MODEL_COHERE=command-r-plus
MODEL_OPENAI=gpt-4o
AI_MODEL_VISION_FALLBACK=qwen/qwen-vl-plus:free

# --- IA: API Keys ---
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
CO_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# --- LangSmith (tracing opcional) ---
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=Osai
LANGSMITH_API_KEY=

# --- Webhook secret (opcional) ---
WEBHOOK_SECRET=

# --- Frontend SECRET_KEY (para encriptar tokens en localStorage) ---
# Generar con: openssl rand -hex 32
SECRET_KEY=coloca_aqui_un_secreto_de_32_bytes_hex

# --- Backups ---
BACKUP_DIR=/home/deploy/backups
